#!/usr/bin/env bash

set -euo pipefail

# 1. Parse target command and args
if [ "$#" -lt 1 ]; then
  echo "Usage: $0 <command> [args...]" >&2
  exit 1
fi

TARGET_CMD="$1"
CMD_ARGS=("${@:2}")

# 2. Identify the real binary in the PATH (excluding this script's directory)
REAL_CMD=""
SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
while IFS= read -r cmd; do
  [ -z "$cmd" ] && continue
  cmd_dir="$(cd "$(dirname "$cmd")" && pwd)"
  if [ "$cmd_dir" != "$SELF_DIR" ]; then
    REAL_CMD="$cmd"
    break
  fi
done < <(which -a "$TARGET_CMD" 2>/dev/null || true)

if [ -z "$REAL_CMD" ]; then
  echo "Error: real $TARGET_CMD not found in PATH" >&2
  exit 1
fi

# 3. Conditions to bypass kube-select-run entirely (run the command transparently):
# - If --kubeconfig option is explicitly passed in arguments (user specified config)
# - If KUBECONFIG env var points to /dev/fd/* or /proc/* (process substitution)
# - If it's a shell completion command (contains __complete)
BYPASS=0

case "${KUBECONFIG:-}" in
  /dev/fd/*|/proc/*)
    BYPASS=1
    ;;
esac

for arg in "${CMD_ARGS[@]}"; do
  if [ "$arg" = "__complete" ]; then
    BYPASS=1
    break
  elif [[ "$arg" =~ ^--kubeconfig ]]; then
    BYPASS=1
    break
  fi
done

if [ "$BYPASS" -eq 1 ]; then
  exec "$REAL_CMD" "${CMD_ARGS[@]}"
fi

# 4. Retrieve vault name and file list from 1Password item
if which bkt >/dev/null 2>&1; then
  ITEM_INFO=$(bkt --ttl 1h -- op item get kubeconfigs --format=json 2>/dev/null)
else
  ITEM_INFO=$(op item get kubeconfigs --format=json 2>/dev/null)
fi
if [ -z "$ITEM_INFO" ]; then
  echo "Error: Failed to retrieve 'kubeconfigs' item from 1Password." >&2
  echo "Please make sure you are signed in ('op signin')." >&2
  exit 1
fi

VAULT_NAME=$(echo "$ITEM_INFO" | jq -r '.vault.name')
if [ -z "$VAULT_NAME" ] || [ "$VAULT_NAME" = "null" ]; then
  VAULT_NAME="Personal"
fi

FILES=$(echo "$ITEM_INFO" | jq -r '.files[].name' | grep -v '^$')
if [ -z "$FILES" ]; then
  echo "Error: No files found attached to 'kubeconfigs' item in 1Password." >&2
  exit 1
fi

# 5. Prompt the user to select config file or use default
SELECTED_NAME=""
FORCE_DEFAULT=0

# If stdin/stdout is not a TTY (pipe, redirection), or KUBE_NO_PECO=1, force using default config instead of interactive peco
if [ ! -t 0 ] || [ ! -t 1 ]; then
  FORCE_DEFAULT=1
fi
if [ "${KUBE_NO_PECO:-}" = "1" ]; then
  FORCE_DEFAULT=1
fi

if [ -n "${KUBECONFIG_NAME:-}" ]; then
  # Check if the specified config name exists in the 1Password item files
  if echo "$FILES" | grep -Fqx "$KUBECONFIG_NAME"; then
    SELECTED_NAME="$KUBECONFIG_NAME"
  else
    echo "Error: Specified config '$KUBECONFIG_NAME' not found in 1Password 'kubeconfigs' item." >&2
    exit 1
  fi
elif [ "$FORCE_DEFAULT" -eq 0 ] && [ "${KUBE_SELECT_INTERACTIVE:-0}" = "1" ]; then
  SELECTED_NAME=$(echo "$FILES" | peco --prompt="Select Kubeconfig >")
else
  # Prefer k3s.yaml if it exists in the list, otherwise use the first one
  if echo "$FILES" | grep -Fqx "k3s.yaml"; then
    SELECTED_NAME="k3s.yaml"
  else
    SELECTED_NAME=$(echo "$FILES" | head -n 1)
  fi
fi

if [ -z "$SELECTED_NAME" ]; then
  echo "Cancelled or no config found." >&2
  exit 1
fi

# 6. Execute real command with the selected config via a temporary file in memory (/dev/shm)
TEMP_CONFIG=$(mktemp -p /dev/shm)
trap 'rm -f "$TEMP_CONFIG"' EXIT

op read "op://${VAULT_NAME}/kubeconfigs/${SELECTED_NAME}" > "$TEMP_CONFIG" 2>/dev/null

KUBE_NO_PECO=1 KUBECONFIG="$TEMP_CONFIG" "$REAL_CMD" "${CMD_ARGS[@]}"
