#!/usr/bin/env bash

set -euo pipefail

# 1. Locate glab.exe
GLAB_EXE="$(command -v glab.exe 2>/dev/null || true)"

if [ -z "$GLAB_EXE" ]; then
  echo "Error: glab.exe not found in PATH" >&2
  exit 1
fi

# 2. Convert WSL paths to Windows paths for arguments that refer to existing files/dirs
args=()
for arg in "$@"; do
  # Check if the argument is an existing file or directory in WSL
  if [ -e "$arg" ]; then
    args+=("$(wslpath -w "$arg")")
  else
    args+=("$arg")
  fi
done

# 3. Execute glab.exe
exec "$GLAB_EXE" "${args[@]}"
