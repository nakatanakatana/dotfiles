#!/usr/bin/env bash

set -euo pipefail

# 1. Locate aws-vault.exe
AWS_VAULT_EXE="$(command -v aws-vault.exe 2>/dev/null || true)"

if [ -z "$AWS_VAULT_EXE" ]; then
  echo "Error: aws-vault.exe not found in PATH" >&2
  exit 1
fi

# 2. Set backend to wincred
export AWS_VAULT_BACKEND=wincred

# 3. Convert WSL paths to Windows paths for arguments that refer to existing files/dirs
args=()
for arg in "$@"; do
  # Check if the argument is an existing file or directory in WSL
  if [ -e "$arg" ]; then
    args+=("$(wslpath -w "$arg")")
  else
    args+=("$arg")
  fi
done

# 4. Execute aws-vault.exe
exec "$AWS_VAULT_EXE" "${args[@]}"
