{
  "colorScheme": "solarized dark",
  "enableTerminalSandbox": true,
  "model": "Gemini 3.6 Flash (High)",
  "notifications": true,
  "permissions": {
    "ask": [
      "unsandboxed(gh pr create)",
      "unsandboxed(git commit)",
      "unsandboxed(git push)"
    ],
    "allow": [
      "command(CI=true npm test)",
      "command(buf)",
      "command(cat)",
      "command(go build)",
      "command(go test)",
      "command(go tool)",
      "command(golangci-lint)",
      "command(grep)",
      "command(head)",
      "command(ls)",
      "command(make)",
      "command(mkdir)",
      "command(npm ci)",
      "command(npm run)",
      "command(npm test)",
      "command(sqlc)",
      "command(tail)",
      "command(wc)",
      "unsandboxed(gh api --method GET)",
      "unsandboxed(gh auth status)",
      "unsandboxed(gh pr list)",
      "unsandboxed(gh pr view)",
      "unsandboxed(gh run list)",
      "unsandboxed(gh run view)",
      "unsandboxed(gh search prs)",
      "unsandboxed(git)",
      "unsandboxed(glab auth status)",
      "unsandboxed(glab ci status)",
      "unsandboxed(glab ci trace)",
      "unsandboxed(glab ci view)",
      "unsandboxed(glab issue list)",
      "unsandboxed(glab issue view)",
      "unsandboxed(glab mr list)",
      "unsandboxed(glab mr view)",
      "unsandboxed(glab run list)",
      "unsandboxed(glab run view)"
    ]
  },
  "showFeedbackSurvey": false,
  "statusLine": {
    "type": "command",
    "command": "node ~/.gemini/antigravity-cli/statusline.ts",
    "enabled": true
  },
  "trustedWorkspaces": [
  ]
}
