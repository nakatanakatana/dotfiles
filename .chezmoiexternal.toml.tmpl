[".tmux/plugins/tpm"]
    type = "archive"
    url = "https://github.com/tmux-plugins/tpm/archive/master.tar.gz"
    exact = true
    stripComponents = 1
    refreshPeriod = "168h"

[".config/git-completion.bash"]
    type = "file"
    url = "https://raw.githubusercontent.com/git/git/master/contrib/completion/git-completion.bash"
    refreshPeriod = "168h"

[".config/git-prompt.sh"]
    type = "file"
    url = "https://raw.githubusercontent.com/git/git/master/contrib/completion/git-prompt.sh"
    refreshPeriod = "168h"

[".claude/projects/prices.json"]
    type = "file"
    url = "https://raw.githubusercontent.com/BerriAI/litellm/main/model_prices_and_context_window.json"
    refreshPeriod = "24h"

[".cursor/plugins/local/superpowers"]
    type = "git-repo"
    url = "https://github.com/obra/superpowers.git"
    refreshPeriod = "12h"
    [".cursor/plugins/local/superpowers".pull]
        args = ["--ff-only"]

[".agents/skills/modern-web-guidance"]
    type = "archive"
    url = "https://github.com/GoogleChrome/modern-web-guidance/archive/refs/heads/main.tar.gz"
    exact = true
    include = ["*/skills/modern-web-guidance/**"]
    stripComponents = 3
    refreshPeriod = "168h"

[".agents/skills/japanese-tech-writing/SKILL.md"]
    type = "file"
    url = "https://gist.githubusercontent.com/k16shikano/fd287c3133457c4fd8f5601d34aa817d/raw/SKILL.md"
    refreshPeriod = "168h"

[".agents/skills/cognitive-rhythm-writing/SKILL.md"]
    type = "file"
    url = "https://gist.githubusercontent.com/k16shikano/eb2929f13ed19c97188393d297be8432/raw/SKILL.md"
    refreshPeriod = "168h"


{{- if and (eq .chezmoi.os "linux") (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
{{-   $arch := "" }}
{{-   if eq .chezmoi.arch "amd64" }}
{{-     $arch = "x86_64" }}
{{-   else if eq .chezmoi.arch "arm64" }}
{{-     $arch = "arm64" }}
{{-   end }}
{{-   if $arch }}

[".local/bin/wsl-keyring"]
    type = "file"
    # renovate: datasource=github-releases depName=nakatanakatana/mytools
    url = "https://github.com/nakatanakatana/mytools/releases/download/v0.5.0/wsl-keyring_Linux_{{ $arch }}"
    executable = true
{{-   end }}
{{- end }}

