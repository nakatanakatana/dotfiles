{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "github>aquaproj/aqua-renovate-config#2.12.1",
    "github>nakatanakatana/renovate-config#0.0.2"
  ],
  "configMigration": true,
  "prHourlyLimit": 10,
  "packageRules": [
    {
      "matchPackageNames": [
        "nodejs/node"
      ],
      "allowedVersions": "/^v2(2|4)./"
    },
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "matchPackageNames": ["twistedpair/google-cloud-sdk"],
      "automerge": true,
      "platformAutomerge": true
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)\\.chezmoiexternal\\.toml\\.tmpl$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+?) depName=(?<depName>[^\\s]+?)(?: versioning=(?<versioning>[a-z-]+?))?\\s+url\\s*=\\s*\"https://github.com/[^/]+/[^/]+/releases/download/(?<currentValue>[^/]+)/"
      ]
    }
  ]
}
