{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "model": "lmstudio/google/gemma-4-e4b",
  "small_model": "openai/gpt-5.1-codex-mini",
  "provider": {
    "local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local LLM",
      "options": {
        "baseURL": "http://localhost:1234/v1",
        "apiKey": "lm-studio"
      },
      "models": {
        "google/gemma-4-e4b": {
          "name": "gemma-4-e4b",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        }
      }
    }
  },
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "permission": {
    "*": "ask",
    "skill": "allow",
    "bash": {
      "*": "ask",
      "buf *": "allow",
      "cat *": "allow",
      "gh api --method GET *": "allow",
      "gh pr list *": "allow",
      "gh pr view *": "allow",
      "gh run list *": "allow",
      "gh run view *": "allow",
      "git add *": "allow",
      "git *": "allow",
      "git commit *": "ask",
      "git diff *": "allow",
      "git log *": "allow",
      "git merge *": "ask",
      "git notes *": "allow",
      "git push *": "ask",
      "git show *": "allow",
      "git status *": "allow",
      "go build *": "allow",
      "go mod tidy": "allow",
      "go test *": "allow",
      "go test": "allow",
      "go tool *": "allow",
      "gofmt *": "allow",
      "glab auth status": "allow",
      "glab ci status": "allow",
      "glab ci view": "allow",
      "glab issue list": "allow",
      "glab issue view": "allow",
      "glab mr list": "allow",
      "glab mr view": "allow",
      "glab run list": "allow",
      "glab run view": "allow",
      "golangci-lint *": "allow",
      "golangci-lint": "allow",
      "grep *": "allow",
      "grep": "allow",
      "head *": "allow",
      "ls *": "allow",
      "make *": "allow",
      "mkdir *": "allow",
      "npm ci": "allow",
      "npm run *": "allow",
      "npm view *": "allow",
      "npm test *": "allow",
      "CI=true npm test *": "allow",
      "npx *": "deny",
      "openspec *": "allow",
      "rg *": "allow",
      "sqlc *": "allow",
      "tail *": "allow",
      "tree": "allow",
      "wc *": "allow"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "codesearch": "allow",
    "edit": "allow",
    "external_directory": "deny",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "question": "allow",
    "task": "ask",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow"
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    }
  }
}
